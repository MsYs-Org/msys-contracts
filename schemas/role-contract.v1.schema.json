{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://msys.local/schemas/role-contract.v1.json",
  "title": "MSYS versioned role contract descriptor v1",
  "description": "Language-neutral role declaration, mIPC surface, JSON value shapes, and executable conformance cases.",
  "type": "object",
  "required": [
    "schema",
    "id",
    "role",
    "version",
    "status",
    "summary",
    "channel",
    "target",
    "provider",
    "types",
    "methods",
    "events",
    "artifacts",
    "dependencies",
    "errors"
  ],
  "properties": {
    "$schema": {"const": "https://msys.local/schemas/role-contract.v1.json"},
    "schema": {"const": "msys.role-contract.v1"},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*\\.v[1-9][0-9]*$"},
    "role": {"$ref": "#/$defs/role"},
    "version": {"$ref": "#/$defs/semver"},
    "status": {"enum": ["experimental", "stable", "deprecated"]},
    "summary": {"$ref": "#/$defs/nonEmptyString"},
    "channel": {"enum": ["mipc", "supervisor-lifecycle"]},
    "target": {"type": "string", "pattern": "^role:[a-z][a-z0-9.-]*$"},
    "provider": {"$ref": "#/$defs/provider"},
    "types": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9._-]*$"},
      "additionalProperties": {"$ref": "#/$defs/valueSchema"}
    },
    "methods": {
      "type": "array",
      "items": {"$ref": "#/$defs/method"}
    },
    "events": {
      "type": "array",
      "items": {"$ref": "#/$defs/event"}
    },
    "artifacts": {
      "type": "array",
      "items": {"$ref": "#/$defs/artifact"}
    },
    "dependencies": {
      "type": "array",
      "items": {"$ref": "#/$defs/dependency"}
    },
    "errors": {
      "type": "object",
      "propertyNames": {"pattern": "^[A-Z][A-Z0-9_]{1,63}$"},
      "additionalProperties": {"$ref": "#/$defs/error"}
    }
  },
  "patternProperties": {"^x-[a-z0-9][a-z0-9._-]*$": true},
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "role": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*$"},
    "name": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
    "errorCode": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,63}$"},
    "provider": {
      "type": "object",
      "required": ["exclusive", "readiness_modes", "lifecycle_modes", "requires_control_channel"],
      "properties": {
        "exclusive": {"type": "boolean"},
        "readiness_modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["exec", "mipc-ready", "x11-display"]}
        },
        "lifecycle_modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["session", "background", "on-demand", "manual"]}
        },
        "windowing_required": {"type": "boolean"},
        "windowing_modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["window", "fullscreen", "background", "overlay", "display-provider"]}
        },
        "required_interfaces": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/name"}
        },
        "required_capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/name"}
        },
        "requires_control_channel": {"type": "boolean"}
      },
      "patternProperties": {"^x-[a-z0-9][a-z0-9._-]*$": true},
      "additionalProperties": false
    },
    "method": {
      "type": "object",
      "required": [
        "name",
        "summary",
        "since",
        "required",
        "idempotent",
        "mutates",
        "request",
        "response",
        "errors",
        "conformance"
      ],
      "properties": {
        "name": {"$ref": "#/$defs/name"},
        "summary": {"$ref": "#/$defs/nonEmptyString"},
        "since": {"$ref": "#/$defs/semver"},
        "required": {"type": "boolean"},
        "idempotent": {"type": "boolean"},
        "mutates": {"type": "boolean"},
        "request": {"$ref": "#/$defs/valueSchema"},
        "response": {"$ref": "#/$defs/valueSchema"},
        "errors": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/errorCode"}
        },
        "conformance": {
          "type": "array",
          "items": {"$ref": "#/$defs/case"}
        }
      },
      "patternProperties": {"^x-[a-z0-9][a-z0-9._-]*$": true},
      "additionalProperties": false
    },
    "case": {
      "type": "object",
      "required": ["id", "mode", "request", "expect"],
      "properties": {
        "id": {"$ref": "#/$defs/name"},
        "mode": {"enum": ["safe", "mutating"]},
        "request": true,
        "expect": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {"enum": ["return", "error"]},
            "codes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/errorCode"}
            }
          },
          "additionalProperties": false
        }
      },
      "patternProperties": {"^x-[a-z0-9][a-z0-9._-]*$": true},
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "required": ["topic", "direction", "required", "payload", "summary"],
      "properties": {
        "topic": {"$ref": "#/$defs/name"},
        "direction": {"enum": ["publish", "subscribe"]},
        "required": {"type": "boolean"},
        "payload": {"$ref": "#/$defs/valueSchema"},
        "summary": {"$ref": "#/$defs/nonEmptyString"}
      },
      "patternProperties": {"^x-[a-z0-9][a-z0-9._-]*$": true},
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["name", "transport", "required", "payload", "summary"],
      "properties": {
        "name": {"$ref": "#/$defs/name"},
        "transport": {"const": "readiness-document"},
        "required": {"type": "boolean"},
        "payload": {"$ref": "#/$defs/valueSchema"},
        "summary": {"$ref": "#/$defs/nonEmptyString"}
      },
      "patternProperties": {"^x-[a-z0-9][a-z0-9._-]*$": true},
      "additionalProperties": false
    },
    "dependency": {
      "type": "object",
      "required": ["target", "methods", "required", "summary"],
      "properties": {
        "target": {
          "type": "string",
          "pattern": "^(?:msys\\.core|(?:role|interface):[a-z][a-z0-9._:-]*)$"
        },
        "methods": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/name"}
        },
        "required": {"type": "boolean"},
        "summary": {"$ref": "#/$defs/nonEmptyString"}
      },
      "patternProperties": {"^x-[a-z0-9][a-z0-9._-]*$": true},
      "additionalProperties": false
    },
    "error": {
      "type": "object",
      "required": ["summary", "retryable"],
      "properties": {
        "summary": {"$ref": "#/$defs/nonEmptyString"},
        "retryable": {"type": "boolean"}
      },
      "patternProperties": {"^x-[a-z0-9][a-z0-9._-]*$": true},
      "additionalProperties": false
    },
    "valueSchema": {
      "oneOf": [
        {"type": "boolean"},
        {
          "type": "object",
          "properties": {
            "$ref": {"type": "string", "pattern": "^#/types/[a-z][a-z0-9._-]*$"},
            "$comment": {"type": "string"},
            "description": {"type": "string"},
            "type": {
              "oneOf": [
                {"enum": ["object", "array", "string", "integer", "number", "boolean", "null"]},
                {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {"enum": ["object", "array", "string", "integer", "number", "boolean", "null"]}
                }
              ]
            },
            "properties": {
              "type": "object",
              "additionalProperties": {"$ref": "#/$defs/valueSchema"}
            },
            "required": {
              "type": "array",
              "uniqueItems": true,
              "items": {"type": "string"}
            },
            "additionalProperties": {"$ref": "#/$defs/valueSchema"},
            "items": {"$ref": "#/$defs/valueSchema"},
            "enum": {"type": "array", "minItems": 1, "uniqueItems": true},
            "const": true,
            "oneOf": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/valueSchema"}
            },
            "anyOf": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/valueSchema"}
            },
            "allOf": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/valueSchema"}
            },
            "minItems": {"type": "integer", "minimum": 0},
            "maxItems": {"type": "integer", "minimum": 0},
            "uniqueItems": {"type": "boolean"},
            "minLength": {"type": "integer", "minimum": 0},
            "maxLength": {"type": "integer", "minimum": 0},
            "pattern": {"type": "string"},
            "minimum": {"type": "number"},
            "maximum": {"type": "number"},
            "minProperties": {"type": "integer", "minimum": 0},
            "maxProperties": {"type": "integer", "minimum": 0}
          },
          "patternProperties": {"^x-[a-z0-9][a-z0-9._-]*$": true},
          "additionalProperties": false
        }
      ]
    }
  }
}
