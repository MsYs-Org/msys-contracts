{
  "schema": "msys.profile.v1",
  "id": "mobile-spi",
  "roles": {
    "launcher": ["org.msys.shell.pyside:launcher"],
    "system-chrome": ["org.msys.shell.pyside:chrome"],
    "window-policy": ["org.msys.x11.session:window-policy"],
    "window-manager": ["org.msys.x11.session:window-policy"],
    "notification-presenter": ["org.msys.shell.pyside:notifications"],
    "notification-center": ["org.msys.shell.pyside:notification-center"],
    "task-switcher": ["org.msys.shell.pyside:task-switcher"],
    "chooser": ["org.msys.shell.pyside:intent-chooser"],
    "screen-shield": ["org.msys.shell.pyside:screen-shield"],
    "transition-presenter": ["org.msys.shell.pyside:transitions"],
    "hal-manager": ["org.msys.hal.linux:manager"],
    "navigation-bar": [
      "org.msys.shell.pyside:navigation",
      "org.msys.shell.pyside:navigation-pill"
    ],
    "install-agent": ["org.msys.core.install:install-agent"],
    "update-agent": ["org.msys.core.install:update-agent"],
    "display-output": ["org.msys.openstick.ch347:x11-spi-touch-output"]
  },
  "startup": [
    "org.msys.openstick.ch347:x11-spi-touch-output",
    "org.msys.x11.session:window-policy",
    "org.msys.core.install:install-agent",
    "org.msys.core.install:update-agent",
    "org.msys.hal.linux:manager",
    "org.msys.shell.pyside:chrome",
    "org.msys.shell.pyside:transitions",
    "org.msys.shell.pyside:status-agent",
    "org.msys.shell.pyside:notifications",
    "org.msys.shell.pyside:notification-center",
    "org.msys.shell.pyside:task-switcher",
    "org.msys.shell.pyside:intent-chooser",
    "org.msys.shell.pyside:navigation",
    "org.msys.shell.pyside:launcher"
  ],
  "env": {
    "FONTCONFIG_FILE": "/opt/msys/current/msys-x11-session/files/share/fontconfig/msys-fonts.conf",
    "MSYS_LAYOUT_PROFILE": "mobile",
    "MSYS_ORIENTATION": "auto",
    "MSYS_INSETS": "auto"
  }
}
